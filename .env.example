# Copy this file to .env and fill in your values.
# Lines starting with # are comments and are ignored.
#
# Quick start:
#   cp .env.example .env
#   # Edit .env with your keys
#   pip install -r requirements.txt
#   cd frontend && npm install && npm run build && cd ..
#   uvicorn backend.main:app --reload

# ── Required ──────────────────────────────────────────────────────────────────

# Your Anthropic API key — the AI Dungeon Master won't start without this.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ──────────────────────────────────────────────────────────────────

# SQLite (default — file is created automatically, no setup needed)
DATABASE_URL=sqlite+aiosqlite:///./dungeon_master.db

# PostgreSQL alternative (uncomment and fill in if you prefer Postgres)
# DATABASE_URL=postgresql://user:password@localhost:5432/dungeon_master

# ── Optional: Text-to-Speech ──────────────────────────────────────────────────

# ElevenLabs TTS — leave blank to disable (browser TTS is always available)
# Get a key at https://elevenlabs.io/
ELEVENLABS_API_KEY=

# OpenAI TTS + DALL-E image generation — leave blank to disable both
# Get a key at https://platform.openai.com/
OPENAI_API_KEY=

# ── Security ──────────────────────────────────────────────────────────────────

# Protects the /api/admin/backup endpoint. Set to a long random string.
# Leave blank to disable the backup endpoint entirely.
ADMIN_KEY=

# Comma-separated list of origins allowed to call the API.
# In production set this to your public URL, e.g. https://myapp.fly.dev
CORS_ORIGINS=http://localhost:5173
